# ------------------------------------------------------------------------------
# TiyGate local development environment template
# ------------------------------------------------------------------------------
# Copy to `.env` and fill in the real values:
#     cp .env.example .env
#
# `dotenvy::dotenv()` is called at startup, so any variable set here is
# exported into the process unless it is already set in the shell (the
# existing shell value wins). Run the binary from the repo root so it
# picks up `./.env`.
#
# Runtime-tunable parameters (background task intervals, payload archive,
# routing strategy, ingress/upstream tuning, etc.) are configured via the
# Admin UI at /admin/ui/settings. On first start the env values below are
# seeded into the `settings` table as initial defaults; after that the
# settings table is the single source of truth.
# ------------------------------------------------------------------------------


# ---- Server core -----------------------------------------------------------

# Listen address. Default: 0.0.0.0:3000
# Use 127.0.0.1:3000 to keep it loopback-only while debugging.
TIYGATE_LISTEN_ADDR=0.0.0.0:3000

# Deployment mode. `all` (data + control in one process, recommended
# for local dev), `admin` (control plane only, no data plane), or
# `proxy` (data plane only, no /admin/* routes). Default: all
TIYGATE_MODE=all


# ---- Control plane (Admin API + WebUI) ------------------------------------
# Both of these are REQUIRED to use the WebUI. Without a database the
# server runs in legacy in-memory mode and the admin router is not
# mounted; without an admin token the Admin API returns 503.

# SQLite is the easiest local backend. The file is created if missing.
TIYGATE_DATABASE_URL=sqlite://./tiygate.db?mode=rwc
#
# For docker-compose or production, use PostgreSQL:
# TIYGATE_DATABASE_URL=postgres://tiygate:tiygate@localhost:5432/tiygate

# Bearer token for the Admin API. Pick any high-entropy string for
# local dev (e.g. `openssl rand -hex 32`). The WebUI login screen
# asks for this exact value.
# IMPORTANT: rotate before any non-local deployment.
TIYGATE_ADMIN_TOKEN=dev-admin-token-change-me


# ---- Secret encryption (TIYGATE_MASTER_KEY) --------------------------------
# AES-256-GCM master key used to encrypt provider API keys / OAuth
# tokens / S3 credentials at rest. When unset, secrets are stored in
# cleartext (acceptable for local dev only — the server logs a warning).
#
# The value may be 32 raw bytes encoded as either:
#   * 64 lowercase hex characters, or
#   * standard base64.
# Generate one with:
#   openssl rand -hex 32
# TIYGATE_MASTER_KEY=4f1a2b3c4d5e6f708192a3b4c5d6e7f8091a2b3c4d5e6f708192a3b4c5d6e7f8


# ---- Quota counter (multi-replica) -----------------------------------------
# Optional. When set, the gateway shares quota counters across
# replicas via Redis instead of the per-replica in-memory counter.
# NOTE: the binary must be built with the `redis-quota` feature for
# this to take effect:
#     cargo build -p tiygate-server --features redis-quota
# TIYGATE_REDIS_URL=redis://127.0.0.1:6379


# ---- Admin brute-force protection ------------------------------------------
# Optional. Rate-limits failed Admin API login attempts by client IP.
# Defaults: 3 consecutive failures → 5-min lockout; 3 lockouts → 24h
# escalated lockout. When TIYGATE_REDIS_URL is set (and built with the
# `redis-quota` feature), lockout state is shared across replicas;
# otherwise an in-memory limiter is used (single-replica only).
# TIYGATE_ADMIN_BF_MAX_FAILURES=3
# TIYGATE_ADMIN_BF_LOCKOUT_SECS=300
# TIYGATE_ADMIN_BF_MAX_LOCKOUTS=3
# TIYGATE_ADMIN_BF_ESCALATED_LOCKOUT_SECS=86400


# ---- Logging ---------------------------------------------------------------

# tracing-subscriber EnvFilter. Default: info
# Useful for debugging the ingress pipeline:
# RUST_LOG=info,tiygate_server=debug,tiygate_admin=debug
RUST_LOG=info
